rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow users to read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Nested collections for progress, badges, etc.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global glossary (read-only for everyone)
    match /glossary/{termId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin via console
    }

    // Public module data (read-only)
    match /modules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
