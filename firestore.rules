rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // 0. GLOBAL SAFETY NET — deny everything not explicitly permitted
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PRIMITIVES & GLOBAL HELPERS
    // ═══════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ROLE HELPERS
    // ═══════════════════════════════════════════════════════════════════════

    /** Platform-level Super Admin (Catalizia internal) */
    function isSuperAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email == 'gfreyria@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin')
      );
    }

    /** Legacy isAdmin helper kept for backward compatibility */
    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && isEmailVerified() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // V2 MULTI-TENANT HELPERS — NDA-Proof tenant isolation
    // ═══════════════════════════════════════════════════════════════════════

    /**
     * Returns the companyId stored on the caller's user profile.
     * Used to enforce resource.data.companyId == caller's companyId.
     */
    function callerCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    /** True if resource belongs to the same tenant as the caller */
    function isSameTenant() {
      return isSignedIn() &&
             resource.data.companyId == callerCompanyId();
    }

    /** True if incoming write targets the caller's own tenant */
    function incomingIsSameTenant() {
      return isSignedIn() &&
             incoming().companyId == callerCompanyId();
    }

    /**
     * True if the caller is a Company Admin or Owner within their tenant.
     */
    function isCompanyAdmin() {
      return isSignedIn() && isEmailVerified() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyRole in ['admin', 'owner'];
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ENTITY VALIDATIONS
    // ═══════════════════════════════════════════════════════════════════════

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isBanned', 'queriesUsed']) &&
             data.keys().size() <= 25 &&
             data.uid == userId &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin', 'super-admin'] &&
             data.isBanned is bool &&
             data.queriesUsed is int &&
             (!data.keys().hasAny(['displayName']) || (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))) &&
             (!data.keys().hasAny(['photoURL'])    || (data.photoURL    == null || (data.photoURL    is string && data.photoURL.size()    <= 512)));
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['id', 'name', 'tier', 'adminUid', 'adminEmail', 'branding', 'isActive']) &&
             data.name is string && data.name.size() <= 150 &&
             data.tier in ['starter', 'professional', 'enterprise'] &&
             data.adminUid == request.auth.uid &&
             data.isActive is bool;
    }

    function isValidGPT(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'instructions']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.instructions is string && data.instructions.size() <= 2000 &&
             data.isPublic is bool;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['id', 'name', 'ownerId', 'content']) &&
             data.id is string && data.id.size() <= 128 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 255 &&
             data.content is string && data.content.size() <= 500000;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COMPANIES COLLECTION — Core of Multi-Tenant Architecture
    // ═══════════════════════════════════════════════════════════════════════
    match /companies/{companyId} {
      // Only Super Admin can create companies (onboarding)
      allow create: if isSuperAdmin() && isValidId(companyId) && isValidCompany(incoming());

      // Company admin/owner OR Super Admin can read their company doc
      allow get: if isSuperAdmin() ||
                    (isSignedIn() && callerCompanyId() == companyId);

      // Company admins/owners can update branding & settings; Super Admin can update anything
      allow update: if isSuperAdmin() ||
                       (isCompanyAdmin() && callerCompanyId() == companyId &&
                        incoming().diff(existing()).affectedKeys()
                          .hasOnly(['branding', 'appVersion', 'updatedAt']));

      // Only Super Admin can delete (offboard) a company
      allow delete: if isSuperAdmin();

      // Super Admin can list all; a user can list only their own company
      allow list: if isSuperAdmin() || (isSignedIn() && callerCompanyId() == companyId);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Owner, same-tenant company admin, or Super Admin can read
      allow get: if isOwner(userId) || isSuperAdmin() ||
                    (isCompanyAdmin() && isSameTenant());
      allow list: if isSuperAdmin() || (isCompanyAdmin() && isSameTenant());

      // Self-create on first login
      allow create: if isOwner(userId) && isValidUser(incoming(), userId) &&
                       (incoming().role == 'user' ||
                        (incoming().role == 'super-admin' && incoming().email == 'gfreyria@gmail.com'));

      // Self-update (limited fields) OR admin override
      allow update: if (isOwner(userId) || isSuperAdmin() || isCompanyAdmin()) && (
        (isOwner(userId) &&
         incoming().diff(existing()).affectedKeys()
           .hasOnly(['displayName', 'photoURL', 'lastActive', 'queriesUsed', 'imagesUsed',
                     'flagged', 'flaggedAt', 'flagReason', 'companyId', 'companyRole']) &&
         incoming().role == existing().role &&
         incoming().uid  == existing().uid  &&
         incoming().email == existing().email) ||
        isSuperAdmin() ||
        (isCompanyAdmin() && isSameTenant())
      ) && isValidUser(incoming(), userId);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // GPTS COLLECTION — Tenant-scoped GPTs
    // ═══════════════════════════════════════════════════════════════════════
    match /gpts/{gptId} {
      // Public GPTs OR same-tenant GPTs OR Super Admin
      allow get:  if isSignedIn() && (resource.data.isPublic == true || resource.data.userId == request.auth.uid || isSuperAdmin() || isSameTenant());
      allow list: if isSignedIn() && (resource.data.isPublic == true || resource.data.userId == request.auth.uid || isSuperAdmin() || isSameTenant());

      allow create: if isSignedIn() && isValidId(gptId) && isValidGPT(incoming());

      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin()) &&
                       incoming().diff(existing()).affectedKeys()
                         .hasOnly(['name', 'instructions', 'isPublic', 'updatedAt', 'description', 'avatarUrl', 'tags', 'files']) &&
                       isValidGPT(incoming());

      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DOCUMENTS COLLECTION — Tenant-scoped Private Documents
    // ═══════════════════════════════════════════════════════════════════════
    match /documents/{docId} {
      allow get:    if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin() || isSameTenant());
      allow list:   if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin() || isSameTenant());
      allow create: if isSignedIn() && isValidId(docId) && isValidDocument(incoming());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'content', 'updatedAt']) &&
                       isValidDocument(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN CONFIG — Platform-level settings
    // ═══════════════════════════════════════════════════════════════════════
    match /admin/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin() && isValidId(docId);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // GLOBAL SETTINGS
    // ═══════════════════════════════════════════════════════════════════════
    match /settings/{settingId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin() && isValidId(settingId);
    }
  }
}
